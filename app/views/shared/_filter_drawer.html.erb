<div class="fixed inset-0 z-50 hidden bg-slate-900/30"
     data-disclosure-panel="<%= local_assigns.fetch(:target, "filters") %>"
     data-modal-panel
     role="dialog"
     aria-modal="true"
     aria-labelledby="<%= title_id %>">
  <button type="button" class="absolute inset-0 cursor-default" data-disclosure-cancel aria-label="閉じる"></button>

  <aside class="relative flex h-full w-80 max-w-[86vw] flex-col bg-white shadow-xl">
    <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4">
      <h2 id="<%= title_id %>" class="brand-font text-lg font-bold text-slate-900">
        <%= local_assigns.fetch(:title, "絞り込み") %>
      </h2>
      <button type="button" class="rounded-full p-2 text-slate-500 transition hover:bg-slate-100 hover:text-slate-900" data-disclosure-cancel aria-label="閉じる">
        ×
      </button>
    </div>

    <div class="flex-1 space-y-7 overflow-y-auto px-5 py-5">
      <%= yield %>
    </div>

    <% if local_assigns[:reset_path].present? %>
      <div class="border-t border-slate-100 p-5">
        <%= link_to local_assigns.fetch(:reset_label, "絞り込みをリセット"),
                    local_assigns[:reset_path],
                    class: "btn-secondary w-full" %>
      </div>
    <% end %>
  </aside>
</div>
