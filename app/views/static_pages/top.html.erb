<div class="min-h-screen bg-white flex items-center justify-center">
  <div class="text-center">

    <%# アプリタイトル %>
    <h1 class="text-6xl font-light text-gray-800 mb-4 tracking-wide">
      My Stocker
    </h1>

    <%# サブタイトル %>
    <p class="text-2xl text-gray-600 mb-8 font-light">
      ストック管理×レビューアプリ
